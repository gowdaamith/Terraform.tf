  load_balancer_arn = var.load_balancer_arn
  port = 80
  protocol = "HTTP"
  default_action {
    type = "redirect"
    redirect = {
      port = "443"
      protocol = "HTTPS"
      status_code = "HTTPS_301"
    }
  }




}

# what it does is whenever the user hits HTTP (port 80) ,the load balancer tells them to go to HTTS (port 443)


