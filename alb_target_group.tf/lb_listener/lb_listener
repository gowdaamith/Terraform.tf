JWT validation action 

resource "aws_lb_listener" "this"{
  load_balancer_arn = var.load_balancer_arn 
  protocol = 'HTTPS"
  port = "443"
  ssl_policy = "ELBSecurityPolicy-2016-08"
  certificate_arn = aws_iam_server_certificate.test.arn
  
  default_action {
    # instead of redirecting to the login this check if the incoming request already has a valid JWT token 
    type = "jwt_validation "
    

    jwt_validation {
      issuer = "https://example.com"
      # who issued the token (ex: google ,autho, congnito)
      # Used to verify token authenticity 
      jwks_endpoint =  "https://example.com/.well-known/jwks.json"
      # url to fetch the public keys 
      # used to verify JWT signature 
      additional_claim {
        format = "string-array"
        # claim value is an array (muliple values)
        name = "claim_name1'
        # name of the claim inside JWT
        values = ["values1","values2"]
        # allowed values -> request must contain one of these
        additional_claim { 
          format = "string-string"
          # claim value is a string
          name  = "claim_name2"
          # Another claim to validate
          values = ["value1"]
          # must exactly match this value 

            default_action {
              type = "forward"  
              # If JWT is valid → forward request

              target_group_arn = aws_lb_target_group.test.id  
              # Sends traffic to backend (EC2, containers, etc.)
             }
}


