Redirect Action :

resource "aws_lb_listener" "this"{
  load_balancer_arn =  var.load_balancer_arn
  port = "80"
  protocol = "HTTP"
  default_action {
    type = "Redirect "
    redirect {
      port = "443"
      protocol = "HTTPS"
      status_code = "HTTP_301"
    }
  }
}


Fixed-response Action

resource "aws_lb_listener" "this "{
  load_balancer_arn = var.load_balancer_arn
  port = "80"
  protocol = "HTTP"
  
  default_action {
    type = "fixed_response"
    
    fixed_response {
      content_type = "text/plain"
      message_body = "Fixed response content"
      status_code = "200"

    }
  }
}



  
