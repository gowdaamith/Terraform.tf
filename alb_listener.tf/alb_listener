Authenticate-OIDC Action 

resource "aws_lb" "this"{
  
}
resource "aws_lb_target_group" "this"{
  
}
resource "aws_lb_listener" "this" {
  load_balancer_arn = var.load_balaner_arn
  port = "80"
  protocol = "HTTP"
  default_action {
    type = "authenticate-oidc"
    authenticate-oidc {
      authorication_endpoint = "https://example.com/authorization_endpoint"  # this is where the login happens
      client_id = "client_id"   # which app is requesting the login  which is given by the congnito in the app client 
      client_secret = "client_secret" # apps private password 
      issuer  = "https://example.com"  # who issued the token
      token_endpoint =  "https://example.com/token_endpoint"   # after the login the cognito or the google send the authorization code alb exchange this for the ID token and access token 
      user_info_endpoint = "https://example.com/user_info_endpoint"  # used to fetch user details like email .username and attribute 
    }
  }
  default_action {
    type = "forward"
    target_group_arn =var.target_group_arn 

  }
}
